{
  "name": "@xiaojing/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "pnpm --filter @xiaojing/ui run build:desktop && node build.mjs",
    "pack": "pnpm run build && electron-builder",
    "pack:win": "pnpm run build && electron-builder --win --x64",
    "pack:mac": "pnpm run build && electron-builder --mac --arm64 --x64",
    "dev": "XIAOJING_RENDERER_URL=http://localhost:5173 electron .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@xiaojing/agent-runtime": "workspace:*",
    "@xiaojing/executor": "workspace:*",
    "@xiaojing/protocol": "workspace:*",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
