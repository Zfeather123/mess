DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─────────────────────────────────────────────────────────────────────────────
# 以下为本 fork 新增(jin-studio)。说明见 docs/jin/ENV.md
# ⚠️ 不要把真实 key 提交进仓库
# ─────────────────────────────────────────────────────────────────────────────

# ── 模型层:GLM 直连 Anthropic 兼容端点(不要引翻译网关,会丢 prompt caching)──
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_API_KEY=

# ── 视觉工具层:必须走 GLM 原生 OpenAI 端点 ──
# 实测:Anthropic 兼容端点会静默丢弃图片并瞎编(不报错),所以视觉一律封装成工具走这里
GLM_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_OPENAI_API_KEY=
GLM_VISION_MODEL=glm-4.6v
GLM_IMAGE_MODEL=cogview-4
# compose_cover() 用代码渲染中文标题(CogView 写中文全是乱码),需要中文字体
JIN_COVER_FONT_PATH=./assets/fonts/SourceHanSansSC-Bold.otf

# ── 抖音数据:TikHub(服务端 token,不碰用户抖音登录态)──
TIKHUB_API_KEY=
TIKHUB_BASE_URL=https://api.tikhub.io

# ── 算力计费(点数制)──
# ⚠️ 费率必须分三档,不能一口价。
# 实测:带 cache_control 断点的 system 连打两次,input 2788 → 100,
# cache_read_input_tokens=2688(省 96%)。缓存读取的 token 在上游本就按 ~1/10 计价 ——
# 一口价的话,要么用户替缓存买单,要么我们亏。
BILLING_YUAN_PER_1M_INPUT=5.0
BILLING_YUAN_PER_1M_CACHED_INPUT=0.5
BILLING_YUAN_PER_1M_OUTPUT=5.0
BILLING_POINTS_PER_YUAN=100
# CogView 按「张」计费,不是 token 计价
VISION_POINTS_PER_IMAGE=20
# 两阶段扣费的预留 TTL:超时未结算的冻结由 sweeper 回收,
# 否则网关进程猝死会让用户的点数凭空消失(见 packages/billing/src/sweeper.ts)
BILLING_RESERVATION_TTL_MS=900000
JIN_CREDITS_ENFORCE=true

# ── 网关 ──
JIN_GATEWAY_PORT=8787

# ── 品牌占位(品牌定了改 branding/brand.config.json)──
JIN_BRAND_NAME=Jin Studio
JIN_BRAND_PRIMARY_COLOR=#18181b
