# 复制成 .env 后填真值。⚠️ .env 已在 .gitignore,key 绝不进仓库。
# 说明见 docs/gateway/README.md

# ── 模型网关(GLM 直连,不要翻译网关)
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_API_KEY=

# ── 视觉工具专用:GLM 原生 OpenAI 端点
# ⚠️ 不能省。Anthropic 兼容端点看不到图(实测读中文截图 0/6),视觉必须绕到这里。
GLM_NATIVE_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
GLM_VISION_MODEL=glm-4.6v
GLM_IMAGE_MODEL=cogview-4

# ── 封面标题渲染用的中文字体(缺了会渲染成豆腐块)
COVER_FONT_PATH=/usr/share/fonts/truetype/msyh/msyh.ttc

# ── 算力计费(元/100万 token)
# ⚠️ 缓存命中的 input 必须单独一档:实测 prompt caching 省 96%,一口价要么用户替缓存买单、要么我们亏
BILLING_YUAN_PER_1M_INPUT=5.0
BILLING_YUAN_PER_1M_CACHED_INPUT=0.5
BILLING_YUAN_PER_1M_OUTPUT=5.0
BILLING_POINTS_PER_YUAN=100
# CogView 按张计费,不是 token 计价
VISION_POINTS_PER_IMAGE=20

PORT=8787
