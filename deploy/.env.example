# deploy/docker-compose.yml 用的变量。复制成 deploy/.env 后填。
# ⚠️ 真实值走 CI/CD 的 secret store 注入,不要提交

POSTGRES_USER=paperclip
POSTGRES_PASSWORD=            # 必填,生产用随机强密码
POSTGRES_DB=paperclip

PUBLIC_PORT=3100
PAPERCLIP_PUBLIC_URL=http://localhost:3100
BETTER_AUTH_SECRET=           # 必填,随机 32+ 位,生产不能用 dev 值

# 镜像构建时的 Debian apt 换源(只影响 build,不影响运行时)。
# 空 = 用官方源 deb.debian.org(海外/CI 默认)。国内 build 慢就填 mirrors.aliyun.com 或 mirrors.ustc.edu.cn。
DEBIAN_MIRROR=

# 上游 GLM 端点。注意:server 的模型请求走**网关**(compose 里 server.ANTHROPIC_BASE_URL
# 已固定为 http://gateway:8787),这里的 ANTHROPIC_BASE_URL 只喂给 gateway 当上游。
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_API_KEY=            # 必填,GLM key(只在网关里,不下发客户端)

GLM_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_OPENAI_API_KEY=           # 必填,视觉工具走 GLM 原生端点;网关 required
GLM_VISION_MODEL=glm-4.6v
GLM_IMAGE_MODEL=cogview-4

# compose_cover 渲染中文标题用的字体。镜像里由 Dockerfile 装 Noto Sans CJK(=思源黑体),
# 默认路径即下面这个;换字体时改这里 + 确保文件在镜像里。
JIN_COVER_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Bold.ttc

TIKHUB_API_KEY=
TIKHUB_BASE_URL=https://api.tikhub.io

# 算力计费(点数制,三档费率 + 点数换算,均有默认值)
BILLING_YUAN_PER_1M_INPUT=5.0
BILLING_YUAN_PER_1M_CACHED_INPUT=0.5
BILLING_YUAN_PER_1M_OUTPUT=5.0
BILLING_POINTS_PER_YUAN=100
VISION_POINTS_PER_IMAGE=20
BILLING_RESERVATION_TTL_MS=900000
JIN_PRICE_CNY_PER_1M_TOKENS=5
JIN_CREDITS_ENFORCE=true
